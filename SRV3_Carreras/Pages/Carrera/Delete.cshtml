@page
@model SRV3_Carreras.Pages.Carrera.DeleteModel
@{
    ViewData["Title"] = "Eliminar Carrera";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="carrera-delete-container">
    <div class="delete-card">
        <div class="delete-header">
            <i class="fas fa-exclamation-triangle text-danger fa-3x"></i>
            <h2>Eliminar Carrera</h2>
            <p class="text-muted">Esta accion no se puede deshacer</p>
        </div>

        <div class="delete-body">
            <div class="delete-info">
                <div class="info-item">
                    <span class="label">Nombre:</span>
                    <span class="value">@Model.Carrera.Nombre</span>
                </div>
                <div class="info-item">
                    <span class="label">Director:</span>
                    <span class="value">@Model.Carrera.Director</span>
                </div>
                <div class="info-item">
                    <span class="label">Email:</span>
                    <span class="value">@Model.Carrera.Email</span>
                </div>
                <div class="info-item">
                    <span class="label">Telefono:</span>
                    <span class="value">@Model.Carrera.Telefono</span>
                </div>
                <div class="info-item">
                    <span class="label">Institucion:</span>
                    <span class="value">@Model.Carrera.InstitucionNombre</span>
                </div>
            </div>
        </div>

        <div class="delete-footer">
            <form method="post">
                <input type="hidden" asp-for="Carrera.ID" />
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-trash"></i> Confirmar Eliminacion
                </button>
                <a asp-page="/Carrera/Index" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Cancelar
                </a>
            </form>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/carrera.css" />
}