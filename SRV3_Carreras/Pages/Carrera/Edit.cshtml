@page
@model SRV3_Carreras.Pages.Carrera.EditModel
@{
    ViewData["Title"] = "Editar Carrera";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="carrera-form-container">
    <div class="form-header">
        <h2><i class="fas fa-edit"></i> Editar Carrera</h2>
        <a asp-page="/Carrera/Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Volver
        </a>
    </div>

    <div class="form-card">
        <form method="post">
            <input type="hidden" asp-for="Request.ID" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Request.Nombre"></label>
                <input asp-for="Request.Nombre" class="form-control" />
                <span asp-validation-for="Request.Nombre" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Request.Director"></label>
                <input asp-for="Request.Director" class="form-control" />
                <span asp-validation-for="Request.Director" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Request.Email"></label>
                <input asp-for="Request.Email" class="form-control" />
                <span asp-validation-for="Request.Email" class="text-danger"></span>
                <small class="form-text text-muted">Solo se permiten correos @@cuc.ac.cr o @@cuc.cr</small>
            </div>

            <div class="form-group">
                <label asp-for="Request.Telefono"></label>
                <input asp-for="Request.Telefono" class="form-control" />
                <span asp-validation-for="Request.Telefono" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Request.InstitucionNombre"></label>
                <input asp-for="Request.InstitucionNombre" class="form-control" />
                <span asp-validation-for="Request.InstitucionNombre" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Request.InstitucionID"></label>
                <input asp-for="Request.InstitucionID" type="number" class="form-control" />
                <span asp-validation-for="Request.InstitucionID" class="text-danger"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Actualizar Carrera
                </button>
                <a asp-page="/Carrera/Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/carrera.css" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}