          "name": "POST - Crear parametro (201)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Consola: View > Show Postman Console (Ctrl/Cmd+Alt+C)",
                  "console.log('===== ' + pm.info.requestName + ' =====');",
                  "console.log('Status:', pm.response.code, pm.response.status);",
                  "var _b;",
                  "try { _b = JSON.stringify(pm.response.json(), null, 2); }",
                  "catch (e) { _b = pm.response.text(); }",
                  "console.log('Body:', _b);",
                  "pm.test('Codigo esperado 201', function () {",
                  "    pm.expect(pm.response.code).to.eql(201);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"PRUEBA\",\n  \"valor\": \"valor de prueba\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/parametro",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "parametro"
              ]
            },
            "description": "id solo mayusculas, max 10. valor texto libre max 500. -> 201 Created."
          },
          "response": []
        },
