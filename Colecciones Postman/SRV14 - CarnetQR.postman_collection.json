  "item": [
    {
      "name": "Casos exitosos",
      "item": [
        {
          "name": "GET - Carnet QR usuario valido (200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Consola: View > Show Postman Console (Ctrl/Cmd+Alt+C)",
                  "console.log('===== ' + pm.info.requestName + ' =====');",
                  "console.log('Status:', pm.response.code, pm.response.status);",
                  "var _b;",
                  "try { _b = JSON.stringify(pm.response.json(), null, 2); }",
                  "catch (e) { _b = pm.response.text(); }",
                  "console.log('Body:', _b);",
                  "pm.test('Codigo esperado 200', function () {",
                  "    pm.expect(pm.response.code).to.eql(200);",
                  "});",
                  "// Renderiza el QR en la pestana 'Visualize'",
                  "var b64;",
                  "try { b64 = pm.response.json(); } catch (e) { b64 = pm.response.text(); }",
                  "if (typeof b64 === 'string') {",
                  "  pm.visualizer.set(\"<img style='max-width:320px' src='data:image/png;base64,{{img}}'/>\", { img: b64 });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/usuario/qr?identificacion=1-0234-5678",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "usuario",
                "qr"
              ],
              "query": [
                {
                  "key": "identificacion",
                  "value": "1-0234-5678"
                }
              ]
            },
            "description": "Usuario simulado existente. Devuelve el QR en Base64. Vea la pestana 'Visualize' para ver la imagen."
          },
          "response": []
        }
      ]
    },
