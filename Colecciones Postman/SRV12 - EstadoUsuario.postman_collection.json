              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Consola: View > Show Postman Console (Ctrl/Cmd+Alt+C)",
                  "console.log('===== ' + pm.info.requestName + ' =====');",
                  "console.log('Status:', pm.response.code, pm.response.status);",
                  "var _b;",
                  "try { _b = JSON.stringify(pm.response.json(), null, 2); }",
                  "catch (e) { _b = pm.response.text(); }",
                  "console.log('Body:', _b);",
                  "pm.test('Codigo esperado 200', function () {",
                  "    pm.expect(pm.response.code).to.eql(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usuarioIdentificacion\": \"{{usuarioIdentificacion}}\",\n  \"codigoEstado\": \"ACTIVO\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
