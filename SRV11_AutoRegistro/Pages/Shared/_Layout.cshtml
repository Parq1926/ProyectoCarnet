@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Carnet Digital</title>

    <link rel="stylesheet" href="~/css/siteautoregistro.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <div class="app-container">

        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">

            <div class="sidebar-header">
                <div class="logo-sidebar">
                    <div class="logo-icon">CUC</div>
                    <span class="logo-text">Carnet Digital</span>
                </div>
            </div>

            <nav class="sidebar-nav">
                <ul>
                    <li class="active">
                        <a href="#">
                            <i class="fas fa-user-plus"></i>
                            <span>Autoregistro</span>
                        </a>
                    </li>

                    <li>
                        <a href="https://localhost:7019" target="_blank">
                            <i class="fas fa-sign-out-alt"></i>
                            <span>Volver al Sistema</span>
                        </a>
                    </li>
                </ul>
            </nav>

        </aside>

        <!-- Main Content -->
        <main class="main-content">

            <!-- Top Bar -->
            <header class="top-bar">

                <div class="top-bar-left">

                    <button class="menu-toggle" onclick="toggleSidebar()">
                        <i class="fas fa-bars"></i>
                    </button>

                    <span class="page-title">@ViewData["Title"]</span>

                </div>

                <div class="top-bar-right">

                    <div class="user-info">

                        <div class="user-avatar">
                            <i class="fas fa-user-circle"></i>
                        </div>

                        <span class="user-name">Invitado</span>
                        <span class="user-role">(Autoregistro)</span>

                    </div>

                </div>

            </header>

            <!-- MODAL DE MENSAJE -->
            <div id="modalMensaje" class="modal" tabindex="-1" role="dialog">
                <div class="modal-dialog modal-dialog-centered" role="document">
                    <div class="modal-content">
                        <div class="modal-header" style="border-bottom: none; background: white;">
                            <div id="modalIcono" style="margin: 0 auto 10px auto;"></div>
                            <button type="button" class="btn-close" onclick="cerrarModal()" style="position: absolute; right: 15px; top: 10px; font-size: 24px; background: none; border: none; color: #888;">&times;</button>
                        </div>
                        <div class="modal-body" style="text-align: center; padding: 10px 30px 20px;">
                            <h4 id="modalTitulo" style="font-weight: 600; margin-bottom: 12px;"></h4>
                            <p id="modalCuerpo" style="color: #555; font-size: 16px; margin: 0;"></p>
                        </div>
                        <div class="modal-footer" style="justify-content: center; border-top: none; padding: 0 20px 25px;">
                            <button id="modalBoton" class="btn btn-primary" style="padding: 10px 40px; border-radius: 8px; min-width: 120px;">Aceptar</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- MODAL DE CARGA -->
            <div id="modalCarga" class="modal" tabindex="-1" role="dialog">
                <div class="modal-dialog modal-dialog-centered" role="document">
                    <div class="modal-content">
                        <div class="modal-body" style="text-align: center; padding: 40px;">
                            <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
                                <span class="visually-hidden">Cargando...</span>
                            </div>
                            <p id="modalCargaTexto" class="mt-3" style="font-size: 16px; color: #555;">Procesando...</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Page Content -->
            <div class="page-content">
                @RenderBody()
            </div>

        </main>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function toggleSidebar() {
        document.getElementById('sidebar').classList.toggle('open');
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>