@page
@model SRV11_AutoRegistro.Pages.AutoRegistro.IndexModel
@{
    ViewData["Title"] = "Autoregistro";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/siteautoregistro.css" />

<div class="page-header">
    <h2>
        <i class="fas fa-user-plus"></i> Autoregistro de Usuario
    </h2>
    <p class="text-muted">Complete todos los campos para registrarse</p>
</div>

<!-- ALERTAS -->
<div id="alertContainer"></div>

<!-- LOADING -->
<div id="loading" class="loading" style="display:none;">
    <div class="spinner-border"></div>
    <p class="mt-2">Procesando...</p>
</div>

<!-- FORMULARIO -->
<div class="form-card">
    <div class="card">
        <div class="card-body">
            <form id="registroForm" method="post">
                @Html.AntiForgeryToken()

                <!-- Tipo de Usuario -->
                <div class="form-group">
                    <label for="tipoUsuarioId">Tipo de Usuario *</label>
                    <select id="tipoUsuarioId" class="form-control" required>
                        <option value="">Seleccione...</option>
                    </select>
                    <div class="invalid-feedback" id="errTipoUsuarioId"></div>
                </div>

                <!-- Tipo de Identificación -->
                <div class="form-group">
                    <label for="tipoIdentificacionId">Tipo de Identificación *</label>
                    <select id="tipoIdentificacionId" class="form-control" required>
                        <option value="">Seleccione...</option>
                    </select>
                    <div class="invalid-feedback" id="errTipoIdentificacionId"></div>
                </div>

                <!-- Número de Identificación -->
                <div class="form-group">
                    <label for="numeroIdentificacion">Número de Identificación *</label>
                    <input id="numeroIdentificacion" class="form-control" placeholder="Ingrese su número de identificación" required>
                    <div class="invalid-feedback" id="errNumeroIdentificacion"></div>
                </div>

                <!-- Nombre Completo -->
                <div class="form-group">
                    <label for="nombreCompleto">Nombre Completo *</label>
                    <input id="nombreCompleto" class="form-control" placeholder="Ingrese su nombre completo" required>
                    <div class="invalid-feedback" id="errNombreCompleto"></div>
                </div>

                <!-- Correo -->
                <div class="form-group">
                    <label for="email">Correo Electrónico *</label>
                    <input id="email" type="email" class="form-control" placeholder="ejemplo@cuc.ac.cr" required>
                    <div class="invalid-feedback" id="errEmail"></div>
                    <small class="text-muted">El dominio debe coincidir con la institución seleccionada</small>
                </div>

                <!-- Rol -->
                <div class="form-group">
                    <label for="rolId">Rol *</label>
                    <select id="rolId" class="form-control" required>
                        <option value="">Seleccione...</option>
                    </select>
                    <div class="invalid-feedback" id="errRolId"></div>
                </div>

                <!-- Contraseña -->
                <div class="form-group">
                    <label for="contrasena">Contraseña *</label>
                    <input id="contrasena" type="password" class="form-control" placeholder="Mínimo 6 caracteres" required>
                    <div class="invalid-feedback" id="errContrasena"></div>
                </div>

                <!-- Confirmar Contraseña -->
                <div class="form-group">
                    <label for="confirmarContrasena">Confirmar Contraseña *</label>
                    <input id="confirmarContrasena" type="password" class="form-control" placeholder="Repita su contraseña" required>
                    <div class="invalid-feedback" id="errConfirmarContrasena"></div>
                </div>

                <!-- Instituciones -->
                <div class="form-group">
                    <label for="instituciones">Instituciones *</label>
                    <select id="instituciones" class="form-control" multiple style="height: 100px;" required>
                    </select>
                    <div class="invalid-feedback" id="errInstituciones"></div>
                    <small class="text-muted">Mantenga presionada Ctrl para seleccionar múltiples</small>
                </div>

                <!-- Carreras (visible solo para Estudiantes) -->
                <div id="carrerasContainer" style="display: none;">
                    <div class="form-group">
                        <label for="carreras">Carreras *</label>
                        <select id="carreras" class="form-control" multiple style="height: 100px;">
                        </select>
                        <div class="invalid-feedback" id="errCarreras"></div>
                        <small class="text-muted">Mantenga presionada Ctrl para seleccionar múltiples</small>
                    </div>
                </div>

                <!-- Áreas (visible solo para Funcionarios) -->
                <div id="areasContainer" style="display: none;">
                    <div class="form-group">
                        <label for="areas">Áreas *</label>
                        <select id="areas" class="form-control" multiple style="height: 100px;">
                        </select>
                        <div class="invalid-feedback" id="errAreas"></div>
                        <small class="text-muted">Mantenga presionada Ctrl para seleccionar múltiples</small>
                    </div>
                </div>

                <!-- Teléfonos -->
                <div class="form-group">
                    <label>Teléfonos</label>
                    <div id="telefonosContainer">
                        <div class="input-group mb-2">
                            <input type="text" class="form-control telefono-input" placeholder="Número de teléfono" />
                            <button type="button" class="btn btn-outline-secondary agregar-telefono">
                                <i class="fas fa-plus"></i>
                            </button>
                        </div>
                    </div>
                    <small class="text-muted">Ejemplo: 8888-8888</small>
                </div>

                <!-- Botones -->
                <div class="form-group" style="margin-top: 20px;">
                    <button type="button" class="btn btn-success" id="btnRegistrar">
                        <i class="fas fa-user-plus"></i> Registrarse
                    </button>
                    <button type="reset" class="btn btn-secondary">
                        <i class="fas fa-undo"></i> Limpiar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/autoregistro.js?v=2"></script>
}