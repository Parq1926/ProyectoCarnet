<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Carnet Digital CUC</title>
    <link rel="stylesheet" href="~/css/site.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <div class="app-container">
        <!-- ======================================== -->
        <!-- SIDEBAR - MENÚ LATERAL                   -->
        <!-- ======================================== -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <div class="logo-sidebar">
                    <div class="logo-icon">CUC</div>
                    <span class="logo-text">Carnet Digital</span>
                </div>
            </div>
            <nav class="sidebar-nav">
                <ul>
                    <li class="active" id="menu-welcome">
                        <a href="/Welcome">
                            <i class="fas fa-home"></i>
                            <span>Inicio</span>
                        </a>
                    </li>
                    <li id="menu-usuarios">
                        <a href="#" onclick="abrirUsuarios(); return false;">
                            <i class="fas fa-users"></i>
                            <span>Usuarios</span>
                        </a>
                    </li>
                    <li id="menu-tipos-usuario">
                        <a href="#" onclick="abrirTiposUsuario(); return false;">
                            <i class="fas fa-user-tag"></i>
                            <span>Tipos de Usuario</span>
                        </a>
                    </li>
                    <li id="menu-tipos-identificacion">
                        <a href="#" onclick="abrirTiposIdentificacion(); return false;">
                            <i class="fas fa-id-card"></i>
                            <span>Tipos de Identificación</span>
                        </a>
                    </li>
                    <li id="menu-carreras">
                        <a href="#" onclick="abrirCarreras(); return false;">
                            <i class="fas fa-graduation-cap"></i>
                            <span>Carreras</span>
                        </a>
                    </li>
                    <li id="menu-areas">
                        <a href="#" onclick="abrirAreas(); return false;">
                            <i class="fas fa-building"></i>
                            <span>Áreas</span>
                        </a>
                    </li>
                    <li id="menu-instituciones">
                        <a href="#" onclick="abrirInstituciones(); return false;">
                            <i class="fas fa-university"></i>
                            <span>Instituciones</span>
                        </a>
                    </li>
                    <li class="divider"></li>
                    <li>
                        <a href="#" onclick="logout()" class="logout-link">
                            <i class="fas fa-sign-out-alt"></i>
                            <span>Cerrar Sesión</span>
                        </a>
                    </li>
                </ul>
            </nav>
        </aside>

        <main class="main-content">
            <header class="top-bar">
                <div class="top-bar-left">
                    <button class="menu-toggle" onclick="toggleSidebar()">
                        <i class="fas fa-bars"></i>
                    </button>
                    <span class="page-title">@ViewData["Title"]</span>
                </div>
                <div class="top-bar-right">
                    <div class="user-info">
                        <div class="user-avatar">
                            <i class="fas fa-user-circle"></i>
                        </div>
                        <span class="user-name" id="userName">Usuario</span>
                        <span class="user-role" id="userRole"></span>
                    </div>
                </div>
            </header>

            <div class="page-content">
                @RenderBody()
            </div>
        </main>
    </div>

    <script>
        // ========================================
        // 🔐 VALIDACIÓN DE TOKEN Y AUTENTICACIÓN
        // ========================================

        // ✅ Verificar autenticación al cargar cualquier página
        // ========================================
// 🔐 VERIFICACIÓN GLOBAL DE AUTENTICACIÓN
// ========================================
document.addEventListener('DOMContentLoaded', function() {
    const token = localStorage.getItem('accessToken');
    const currentPath = window.location.pathname;
    const isLoginPage = currentPath.includes('/Login');

    console.log('=== LAYOUT LOGIN SRV1 ===');
    console.log('Token:', token ? 'SÍ existe' : 'NO existe');
    console.log('Path:', currentPath);

    // ✅ Si no hay token y no estamos en Login, redirigir
    if (!token && !isLoginPage) {
        console.log('❌ No hay token, redirigiendo a Login');
        localStorage.setItem('redirectMessage', 'Por favor inicie sesión para utilizar el sistema');
        window.location.href = '/Login';
        return;
    }

    // ✅ Si hay token, mostrar datos del usuario
    if (token) {
        const nombre = localStorage.getItem('nombreCompleto') || 'Usuario';
        const tipo = localStorage.getItem('usuarioTipo') || '';
        document.getElementById('userName').textContent = nombre;
        document.getElementById('userRole').textContent = tipo ? `(${tipo})` : '';
        console.log('✅ Usuario autenticado:', nombre);
    }

    // Marcar menú activo
    const menuItems = document.querySelectorAll('.sidebar-nav ul li');
    menuItems.forEach(item => {
        const link = item.querySelector('a');
        if (link) {
            const href = link.getAttribute('href');
            if (href === currentPath || (currentPath === '/' && href === '/Welcome')) {
                item.classList.add('active');
            } else {
                item.classList.remove('active');
            }
        }
    });
});

        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('open');
        }

        function logout() {
            localStorage.clear();
            console.log('✅ Sesión cerrada');
            window.location.href = '/Login';
        }

        // ========================================
        // 🔐 FUNCIONES PARA ABRIR MICROSERVICIOS
        // ========================================

        function abrirUsuarios() {
            const token = localStorage.getItem('accessToken');
            if (!token) {
                alert('Debe iniciar sesión primero');
                window.location.href = '/Login';
                return;
            }
            // ✅ Sin token en URL - se usa localStorage en el microservicio
            window.open('https://localhost:7206/Usuarios', '_blank');
        }

