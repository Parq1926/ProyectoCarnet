<!-- Pages/Shared/_Layout.cshtml -->
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Carnet Digital CUC</title>
    <link rel="stylesheet" href="~/css/site.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <div class="app-container">
        <!-- Sidebar (Menú lateral) -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <div class="logo-sidebar">
                    <div class="logo-icon">CUC</div>
                    <span class="logo-text">Carnet Digital</span>
                </div>
            </div>
            <nav class="sidebar-nav">
                <ul>
                    <!-- Web2 - Inicio -->
                    <li class="active" id="menu-welcome">
                        <a href="/Welcome">
                            <i class="fas fa-home"></i>
                            <span>Inicio</span>
                        </a>
                    </li>

                    <!-- Web4 - Administración de Usuarios -->
                    <li id="menu-usuarios">
                        <a href="#">
                            <i class="fas fa-users"></i>
                            <span>Usuarios</span>
                        </a>
                    </li>
                    <!-- Web5 - Administración de Carreras -->
                    <li id="menu-carreras">
                        <a href="http://localhost:7003/Carrera/Index">
                            <i class="fas fa-graduation-cap"></i>
                            <span>Carreras</span>
                        </a>
                    </li>
                    <!-- Web6 - Administración de Tipos de Usuario -->
                    <li id="menu-tipos-usuario">
                        <a href="#">
                            <i class="fas fa-user-tag"></i>
                            <span>Tipos de Usuario</span>
                        </a>
                    </li>

                    <!-- Web7 - Administración de Tipos de Identificación -->
                    <li id="menu-tipos-identificacion">
                        <a href="#">
                            <i class="fas fa-id-card"></i>
                            <span>Tipos de Identificación</span>
                        </a>
                    </li>

                    <!-- Web8 - Administración de Fotografía -->
                    <li id="menu-fotos">
                        <a href="#">
                            <i class="fas fa-camera"></i>
                            <span>Fotografías</span>
                        </a>
                    </li>

                    <!-- Web9 - Generación de QR -->
                    <li id="menu-qr">
                        <a href="#">
                            <i class="fas fa-qrcode"></i>
                            <span>Generar QR</span>
                        </a>
                    </li>

                    <!-- Web10 - Administracion de Areas -->
                    <li id="menu-areas">
                        <a href="http://localhost:5202/Areas/Index">
                            <i class="fas fa-building"></i>
                            <span>Areas</span>
                        </a>
                    </li>

                    <!-- Web11 - Cambiar Estado de Usuario -->
                    <li id="menu-estado">
                        <a href="#">
                            <i class="fas fa-toggle-on"></i>
                            <span>Estado de Usuario</span>
                        </a>
                    </li>

                    <!-- Web12 - Administracion de Instituciones -->
                    <li id="menu-instituciones">
                        <a href="http://localhost:7002/Instituciones/Index">
                            <i class="fas fa-university"></i>
                            <span>Instituciones</span>
                        </a>
                    </li>

                    <!-- Web13 - Administración de Módulos (Admin) -->
                    <li id="menu-modulos">
                        <a href="#">
                            <i class="fas fa-cubes"></i>
                            <span>Módulos</span>
                        </a>
                    </li>

                    <!-- Web14 - Administración de Roles (Admin) -->
                    <li id="menu-roles">
                        <a href="http://localhost:5191/Roles/Index">
                            <i class="fas fa-lock"></i>
                            <span>Roles</span>
                        </a>
                    </li>

                    <!-- Web15 - Bitácoras -->
                    <li id="menu-bitacoras">
                        <a href="#">
                            <i class="fas fa-clipboard-list"></i>
                            <span>Bitácoras</span>
                        </a>
                    </li>

                    <!-- Web17 - Parámetros -->
                    <li id="menu-parametros">
                        <a href="#">
                            <i class="fas fa-sliders-h"></i>
                            <span>Parámetros</span>
                        </a>
                    </li>

                    <li class="divider"></li>

                    <!-- Cerrar Sesión -->
                    <li>
                        <a href="#" onclick="logout()" class="logout-link">
                            <i class="fas fa-sign-out-alt"></i>
                            <span>Cerrar Sesión</span>
                        </a>
                    </li>
                </ul>
            </nav>
        </aside>

        <!-- Contenido principal -->
        <main class="main-content">
            <!-- Top bar -->
            <header class="top-bar">
                <div class="top-bar-left">
                    <button class="menu-toggle" id="menuToggle" onclick="toggleSidebar()">
                        <i class="fas fa-bars"></i>
                    </button>
                    <span class="page-title">@ViewData["Title"]</span>
                </div>
                <div class="top-bar-right">
                    <div class="user-info">
                        <div class="user-avatar" id="userAvatar">
                            <i class="fas fa-user-circle"></i>
                        </div>
                        <span class="user-name" id="userName">Usuario</span>
                        <span class="user-role" id="userRole">(Administrador)</span>
                    </div>
                </div>
            </header>

            <!-- Contenido de la página -->
            <div class="page-content">
                @RenderBody()
            </div>
        </main>
    </div>

    <script>
            // ✅ Validación de autenticación
            document.addEventListener('DOMContentLoaded', function() {
                const token = localStorage.getItem('accessToken');
                const currentPath = window.location.pathname;
                const isLoginPage = currentPath.includes('/Login');

                if (!token && !isLoginPage) {
                    localStorage.setItem('redirectMessage', 'Por favor inicie sesión para utilizar el sistema');
                    window.location.href = '/Login';
                    return;
                }

                if (token && isLoginPage) {
                    window.location.href = '/Welcome';
                    return;
                }

                if (token) {
                    const nombre = localStorage.getItem('nombreCompleto') || 'Usuario';
                    const tipo = localStorage.getItem('usuarioTipo') || '';
                    document.getElementById('userName').textContent = nombre;
                    document.getElementById('userRole').textContent = tipo ? `(${tipo})` : '';
                }

                // ✅ Marcar el ítem del menú activo según la página actual
                const menuItems = document.querySelectorAll('.sidebar-nav ul li');
                menuItems.forEach(item => {
                    const link = item.querySelector('a');
                    if (link && link.getAttribute('href') === currentPath) {
                        item.classList.add('active');
                    } else if (currentPath === '/' && link && link.getAttribute('href') === '/Welcome') {
                        item.classList.add('active');
                    }
                });
            });

            // Toggle del sidebar en móviles
            function toggleSidebar() {
                document.getElementById('sidebar').classList.toggle('open');
            }

            // Cerrar sesión
            function logout() {
                localStorage.clear();
                window.location.href = '/Login';
            }

    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>